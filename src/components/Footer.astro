---
import type { Locale } from '../i18n/ui';
import { useTranslations, getLocalizedPath } from '../i18n/ui';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
const privacyUrl = getLocalizedPath(lang, '/privacy-policy/');
---
<section class="footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <img class="footer-logo" src="/assets/app_icon.png" alt="EV Charge Tracker" width="56" height="56" />
      <p class="footer-slogan">{t('footer.slogan')}</p>
      <p class="footer-copy">&copy; {currentYear} {t('footer.copyright')} <a
          href="https://mgorbatyuk.dev?utm_source=ev-charging-tracker&utm_medium=referral&utm_campaign=footer"
          target="_blank" rel="noopener noreferrer">Maxim Gorbatyuk</a></p>
    </div>

    <div class="footer-links">
      <h4>{t('footer.projects')}</h4>
      <ul>
        <li><a href="https://mgorbatyuk.dev/journey-wallet/" target="_blank" rel="noopener noreferrer">Journey Wallet (iOS)</a></li>
        <li><a href="https://mgorbatyuk.dev/creativity-hub/" target="_blank" rel="noopener noreferrer">Creativity Hub (iOS)</a></li>
        <li><a href="https://repolyze.app/" target="_blank" rel="noopener noreferrer">repolyze.app</a></li>
        <li><a href="https://mgorbatyuk.dev/slothy-terminal/" target="_blank" rel="noopener noreferrer">Slothy Terminal (macos)</a></li>
        <li><a href="https://techinterview.space/" target="_blank" rel="noopener noreferrer">techinterview.space</a></li>
      </ul>
    </div>

    <div class="footer-links">
      <h4>{t('footer.github')}</h4>
      <ul>
        <li><a href="https://github.com/maximgorbatyuk/ev-charging-tracker" target="_blank" rel="noopener noreferrer">{t('footer.repository')}</a></li>
        <li><a href={privacyUrl}>{t('footer.privacyPolicy')}</a></li>
        <li><a href="https://github.com/maximgorbatyuk/ev-charging-tracker/issues" target="_blank" rel="noopener noreferrer">{t('footer.issues')}</a></li>
        <li><a href="https://github.com/maximgorbatyuk/ev-charging-tracker/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">{t('footer.license')}</a></li>
      </ul>
    </div>
  </div>
</section>
