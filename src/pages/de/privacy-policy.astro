---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PrivacyPolicyContent from '../../components/PrivacyPolicyContent.astro';
import type { Locale } from '../../i18n/ui';
import { useTranslations, getLocalizedPath } from '../../i18n/ui';

const lang: Locale = 'de';
const t = useTranslations(lang);
---

<BaseLayout
  title={t('privacy.meta.title')}
  description={t('privacy.meta.description')}
  ogUrl={`https://evchargetracker.app${getLocalizedPath(lang, '/privacy-policy/')}`}
  lang={lang}
>
  <main class="page">
    <PrivacyPolicyContent lang={lang} />
  </main>
</BaseLayout>
