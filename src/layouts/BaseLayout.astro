---
import '../styles/brutalism-style.css';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import type { Locale } from '../i18n/ui';
import { locales, localeRegions, ogLocales, getLocalizedPath, getCurrentPath } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  ogUrl: string;
  lang?: Locale;
  ogImage?: string;
  themeColor?: string;
  includeJsonLd?: boolean;
}

const {
  title,
  description,
  ogUrl,
  lang = 'en',
  ogImage = 'https://evchargetracker.app/assets/app_icon.png',
  themeColor = '#daf5f0',
  includeJsonLd = false,
} = Astro.props;

const currentPath = getCurrentPath(Astro.url);
const site = Astro.site?.origin ?? 'https://evchargetracker.app';
---

<!DOCTYPE html>
<html lang={lang}>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="theme-color" content={themeColor} />

  <meta name="description" content={description}>
  <meta name="author" content="Maxim Gorbatyuk">

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={ogUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:site_name" content="EV Charge Tracker">
  <meta property="og:locale" content={ogLocales[lang]}>

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content={ogUrl}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <link rel="canonical" href={ogUrl} />
  {locales.map((locale) => (
    <link rel="alternate" hreflang={localeRegions[locale]} href={`${site}${getLocalizedPath(locale, currentPath)}`} />
  ))}
  <link rel="alternate" hreflang="x-default" href={`${site}${currentPath}`} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="icon" href="/favicon.ico" />

  <GoogleAnalytics />

  <!-- WebSite schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "EV Charge Tracker",
      "url": "https://evchargetracker.app/"
    }
  </script>

  <slot name="jsonld" />

  {includeJsonLd && (
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "EV Charge Tracker",
        "operatingSystem": "iOS 18+",
        "applicationCategory": "UtilitiesApplication",
        "description": "Track your electric vehicle charging sessions and expenses, monitor costs per kilometer, and optimize your EV charging experience with our iOS app.",
        "url": "https://evchargetracker.app/",
        "downloadUrl": "https://apps.apple.com/app/id6754165643",
        "author": {
          "@type": "Person",
          "name": "maximgorbatyuk"
        }
      }
    </script>
  )}
</head>

<body>
  <slot />
</body>

</html>
